(let ((val v2 [10 100])
      (val v3 [10 100 1000])
      (val m [[1 2 3] [4 5 6]])
      (fun (@colsum (&t) ($m $n) (mat [Int $m $n]) : [Int $n])
      	(@reduce (Int) ((- $m 1) [$n])
	         (fn ((x [Int $n]) (y [Int $n])) (+ x y))
		       mat))
      (fun (@rowsum (&t) ($m $n) (mat [Int $m $n]) : [Int $m])
        (@colsum (&t) ($n $m) (@transpose2d (Int) ($m $n) mat)))
      )
     (+ (@rowsum (Int) (2 3) m) v2)
  )
