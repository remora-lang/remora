      (fun (conv2d/76-3-128-256-1
            (in [Float 128 76 76])
            (w  [Float 256 128 3 3])
            : [Float 256 5776])
           (matmul/256-1152-76_76
                    (flatten/f/128-9-_ (flatten/f/3-3-_ w))
                    (im2col/76-3-1-128 in)
                    ))
      )
  (conv2d/76-3-128-256-1 input weights)
  )