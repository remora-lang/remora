              in
              (+ (replicate/i/76x76-2 offset)
                 (idxs-of/76-76))))

      (fun (lifted-subarray/f/3x3-2-76
             (in [Float 78 78])
             (offset [Int 3 3 2]) : [Float 3 3 76 76])
         (subarray/f/2-76 in offset))

      (fun (im2col/76-3-1-128 (im [Float 128 76 76]) : [Float 1152 5776])
           (flatten/f/128-9-5776
            (flatten/f/3-3-5776
             (flatten/f/76-76-_
              (lifted-subarray/f/3x3-2-76
               (pad/f/76-1 im 0.0)
               (replicate/i/128-3x3x2 (idxs-of/3-3)))))))

      (fun (dot/1152 (v [Float 1152]) (w [Float 1152]) : [Float])
           (reduce/f/1151 f.+ (f.* v w)))

      (fun (lifted_dot/1152-5776 (v [Float 1152])
                                              (M [Float 1152 5776]) : [Float 5776])
           (dot/1152 v (transpose2d/f/1152-5776 M)))

      (fun (matmul/256-1152-76_76
            (xss [Float 256 1152])
            (yss [Float 1152 5776]) : [Float 256 5776])
