(let (
      (val input undefined-input/128x76x76) ; real world input
      (val weights undefined-weights/256x128x3x3) ; real world input

      (fun (zero-lam (x [Int]) : [Float]) 0.0)
      (fun (replicate/zero/f/1-78 : [Float 1 78])
           [(zero-lam iota/78)])

      (fun (pad/f/76-1 (in [Float 76 76]) (zero [Float]) : [Float 78 78])
           (let ((val (vert-pad : [Float 1 78]) (replicate/zero/f/1-78))
                 (val (hor-pad : [Float 1]) [zero]))
             (append/f/1-77-78
              vert-pad
              (append/f/76-1-78
               (append/f/1-77-_ hor-pad (append/f/76-1-_ in hor-pad))
               vert-pad))))

      (fun (idxs-of/76-76 : [Int 76 76 2])
           (let ((fun (idx-row/76 (i [Int]) : [Int 76 2])
                      (let ((fun (make-idx/76 (i [Int]) (j [Int]) : [Int 2])
                                 [i j]))
                        (make-idx/76 i iota/76))))
             (idx-row/76 iota/76)))


      (fun (idxs-of/3-3
            : [Int 3 3 2])
           (let ((fun (idx-row/3 (i [Int]) : [Int 3 2])
                      (let ((fun (make-idx/3 (i [Int]) (j [Int]) : [Int 2])
                                 [i j]))
                        (make-idx/3 i iota/3))))
             (idx-row/3 iota/3)))


      (fun (subarray/f/2-76
             (in [Float 78 78])
