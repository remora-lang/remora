               (idxs-of/38-38))))

      (fun (lifted-subarray/f/1x1-0-38
            (in [Float 38 38])
            (offset [Int 1 1 2]) : [Float 1 1 38 38])
           (subarray/f/0-38 in offset))

      (fun (im2col/38-1-0-256 (im [Float 256 38 38]) : [Float 256 1444])
           (flatten/f/256-1-1444
            (flatten/f/1-1-1444
             (flatten/f/38-38-_
              (lifted-subarray/f/1x1-0-38
               im
               (replicate/i/256-1x1x2 (idxs-of/1-1)))))))

      (fun (dot/256 (v [Float 256]) (w [Float 256]) : [Float])
           (reduce/f/255 f.+ (f.* v w)))

      (fun (lifted_dot/256-1444 (v [Float 256])
                                                           (M [Float 256 1444]) : [Float 1444])
           (dot/256 v (transpose2d/f/256-1444 M)))

      (fun (matmul/128-256-38_38
            (xss [Float 128 256])
            (yss [Float 256 1444]) : [Float 128 1444])
           (lifted_dot/256-1444 xss yss))
      (fun (conv2d/38-1-256-128-0
            (in [Float 256 38 38])
            (w  [Float 128 256 1 1])
            : [Float 128 1444])
           (matmul/128-256-38_38
            (flatten/f/256-1-_ (flatten/f/1-1-_ w))
            (im2col/38-1-0-256 in)
            ))
      )
  (conv2d/38-1-256-128-0 input weights)
  )