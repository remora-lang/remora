(let (
      (val input undefined-input/256x38x38) ; real world input
      (val weights undefined-weights/128x256x1x1) ; real world input
      

      (fun (idxs-of/38-38 : [Int 38 38 2])
           (let ((fun (idx-row/38 (i [Int]) : [Int 38 2])
                      (let ((fun (make-idx/38 (i [Int]) (j [Int]) : [Int 2])
                                 [i j]))
                        (make-idx/38 i iota/38))))
             (idx-row/38 iota/38)))


      (fun (idxs-of/1-1
            : [Int 1 1 2])
           (let ((fun (idx-row/1 (i [Int]) : [Int 1 2])
                      (let ((fun (make-idx/1 (i [Int]) (j [Int]) : [Int 2])
                                 [i j]))
                        (make-idx/1 i iota/1))))
